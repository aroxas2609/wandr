# Google Maps Platform — enable Maps JavaScript API, Places API (New), and Geocoding API
# Home "Recommended" uses Places API (New) Text Search (not legacy Text Search).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (sb_publishable_...), NOT the secret key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Supabase → Authentication → URL Configuration — add Redirect URLs:
#   http://localhost:8081/**
#   wandr://**
#   exp://**

# --- EAS / TestFlight (not read from .env locally for cloud builds) ---
# Set the same EXPO_PUBLIC_* values as EAS secrets before building:
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_GOOGLE_MAPS_API_KEY --value "..."
