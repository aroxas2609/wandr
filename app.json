{
  "expo": {
    "name": "Wandr",
    "slug": "wandr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wandr",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "ios": {
      "bundleIdentifier": "com.wandr.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Wandr to photograph boarding passes, tickets, and IDs.",
        "NSPhotoLibraryUsageDescription": "Allow Wandr to attach photos of travel documents."
      }
    },
    "android": {
      "package": "com.wandr.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Wandr to attach photos of travel documents.",
          "cameraPermission": "Allow Wandr to photograph boarding passes, tickets, and IDs."
        }
      ],
      [
        "react-native-maps",
        {
          "ios": {}
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
